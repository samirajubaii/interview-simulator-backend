APP_NAME=InterviewAI
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=interviewai
DB_USERNAME=interviewai
DB_PASSWORD=your_db_password_here

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@interviewai.com"
MAIL_FROM_NAME="InterviewAI"

FRONTEND_URL=http://localhost:5173

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis
REDIS_MAX_RETRIES=0
REDIS_PERSISTENT=true

CACHE_STORE=redis

SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local